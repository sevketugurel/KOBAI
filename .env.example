# Gemini API anahtarı (Google AI Studio'dan alın)
GEMINI_API_KEY=your_gemini_api_key_here

# ChromaDB sunucu adresi (docker-compose: chromadb servis adı)
CHROMA_HOST=localhost
# ChromaDB port (docker-compose'da 8001'e map edilmiştir)
CHROMA_PORT=8001
# RAG koleksiyon adı — kod içinde hardcode edilmeyecek
CHROMA_COLLECTION=kobi_mevzuat

# CORS — virgülle ayrılmış origin listesi
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# PDF yükleme limiti (MB)
MAX_PDF_SIZE_MB=10
# Log seviyesi
LOG_LEVEL=INFO

# Gemini model adları (CLAUDE.md uyumlu)
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=gemini-embedding-001
# Embedding boyutu (MRL dengeli)
GEMINI_EMBED_DIM=1536

# Frontend
VITE_API_URL=http://localhost:8000

# ----- v2 (multi-tenant) -----
# Faz 1+'da kullanılır; Faz 0'da yalnızca placeholder.
# Supabase hosted: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Fernet key (entegrasyon kimlik bilgileri şifrelemesi için)
# Üretim: GCP Secret Manager. Dev: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=

# Frontend (Faz 1'de eklenecek)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Faz 4 — cron hatırlatıcı endpoint'i için paylaşılan sır
# Cloud Scheduler header'a X-Cron-Secret koyar.
CRON_SECRET=
REMINDER_WINDOW_DAYS=7
